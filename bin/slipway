#!/usr/bin/env bash
# slipway — machine-wide port registry for local dev.
# https://github.com/primestageprime/slipway
# shellcheck disable=SC2016  # jq programs use $var for jq-level vars, not shell expansion
set -euo pipefail

if (( BASH_VERSINFO[0] < 3 || (BASH_VERSINFO[0] == 3 && BASH_VERSINFO[1] < 2) )); then
  echo "slipway: bash 3.2+ required (found ${BASH_VERSION})" >&2
  exit 1
fi

readonly SLIPWAY_VERSION="1.0.0"
REGISTRY="${SLIPWAY_REGISTRY:-$HOME/.config/slipway/registry.json}"
REGISTRY_VERSION=2
LOCK_TIMEOUT_DS="${SLIPWAY_LOCK_TIMEOUT_DS:-100}"  # tenths of a second

# Exit codes (documented in README). Scripts can branch on these.
readonly E_GENERIC=1 E_USAGE=2 E_NOTFOUND=3 E_EXHAUSTED=4 E_LOCK=5 E_CONFLICT=6 E_SCHEMA=7

die_code() { local c="$1"; shift; echo "slipway: $*" >&2; exit "$c"; }
die() { die_code "$E_GENERIC" "$@"; }
debug() {
  [[ "${SLIPWAY_DEBUG:-0}" != "0" ]] && echo "slipway[debug]: $*" >&2
  return 0
}

command -v jq >/dev/null || die "jq not found in PATH"

# Resolve script directory through symlinks (macOS lacks readlink -f).
_slipway_script_dir() {
  local src="${BASH_SOURCE[0]}" d
  while [[ -L "$src" ]]; do
    d=$(cd "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    [[ "$src" != /* ]] && src="$d/$src"
  done
  cd "$(dirname "$src")" && pwd
}
SLIPWAY_BIN_DIR=$(_slipway_script_dir)
SLIPWAY_LIB="${SLIPWAY_LIB:-$SLIPWAY_BIN_DIR/../lib/slipway/commands.sh}"
if [[ ! -f "$SLIPWAY_LIB" ]]; then
  die "commands library not found at $SLIPWAY_LIB (reinstall slipway, or set SLIPWAY_LIB)"
fi

ensure_registry() {
  umask 0022
  if [[ ! -f "$REGISTRY" ]]; then
    mkdir -p "$(dirname "$REGISTRY")"
    cat > "$REGISTRY" <<JSON
{
  "registry_version": $REGISTRY_VERSION,
  "auto_pool": { "start": 4000, "end": 9999 },
  "reserved": [
    { "port": 5000, "note": "macOS AirPlay Receiver (ControlCenter)" },
    { "port": 7000, "note": "macOS AirPlay Receiver (ControlCenter)" }
  ],
  "claims": {}
}
JSON
  fi
  migrate_registry
  validate_registry
}

validate_registry() {
  if ! jq -e '
    has("auto_pool") and
    (.auto_pool | has("start") and has("end")) and
    (.auto_pool.start | type == "number") and
    (.auto_pool.end   | type == "number") and
    (.auto_pool.end >= .auto_pool.start) and
    has("claims") and
    (.claims | type == "object") and
    ((.reserved // []) | type == "array")
  ' "$REGISTRY" >/dev/null; then
    die_code "$E_SCHEMA" "registry schema invalid: $REGISTRY"
  fi
}

migrate_registry() {
  # Pre-migration sanity check: the file must be a JSON object with at least
  # one recognizable field (auto_pool, port_range, claims, or apps).
  if ! jq -e '
    type == "object" and (has("auto_pool") or has("port_range") or has("claims") or has("apps") or has("registry_version"))
  ' "$REGISTRY" >/dev/null 2>&1; then
    die_code "$E_SCHEMA" "registry schema invalid: $REGISTRY"
  fi
  local v
  v=$(jq -r '.registry_version // 0' "$REGISTRY")
  if (( v > REGISTRY_VERSION )); then
    die "registry_version $v is newer than this slipway (knows $REGISTRY_VERSION); upgrade slipway"
  fi
  if (( v < REGISTRY_VERSION )); then
    acquire_lock
    # Re-read under lock
    v=$(jq -r '.registry_version // 0' "$REGISTRY")
    if (( v < REGISTRY_VERSION )); then
      # Migrate from v0/v1 (range-based) to v2 (per-port claims)
      write_unlocked --argjson vv "$REGISTRY_VERSION" '
        # Convert port_range → auto_pool
        (if .port_range then {auto_pool: .port_range} else {auto_pool: (.auto_pool // {start:4000, end:9999})} end) as $pool
        # Convert apps (range-based) → claims (per-port, port = start)
        | (if .apps then
            (.apps | to_entries | map({key: .key, value: {port: .value.start}}) | from_entries)
          else
            (.claims // {})
          end) as $claims
        # Convert reserved entries: {start,end} → {port} (use start as port)
        | ((.reserved // []) | map(
            if .port then .
            elif .start then {port: .start} + (if .note then {note} else {} end)
            else .
            end
          )) as $res
        | {
            registry_version: $vv,
            auto_pool: $pool.auto_pool,
            reserved: $res,
            claims: $claims
          }
      '
    fi
  fi
}

# Atomic-ish locking via mkdir (POSIX atomic). flock is not available on
# macOS by default, so we use a lockdir with PID liveness + double-read
# TOCTOU guard for stale recovery.
LOCK_HELD=0
_slipway_cleanup() {
  if (( LOCK_HELD == 1 )); then
    rm -rf "${REGISTRY}.lock" 2>/dev/null || true
  fi
  return 0
}
trap _slipway_cleanup EXIT INT TERM HUP

acquire_lock() {
  (( LOCK_HELD == 0 )) || return 0
  local lock="${REGISTRY}.lock"
  local i=0 pid1 pid2
  debug "acquire_lock: $lock (timeout=$((LOCK_TIMEOUT_DS/10))s)"
  while ! mkdir "$lock" 2>/dev/null; do
    pid1=$(cat "$lock/pid" 2>/dev/null || true)
    if [[ -n "$pid1" ]] && ! kill -0 "$pid1" 2>/dev/null; then
      sleep 0.05
      pid2=$(cat "$lock/pid" 2>/dev/null || true)
      if [[ "$pid1" == "$pid2" ]] && ! kill -0 "$pid1" 2>/dev/null; then
        rm -rf "$lock" 2>/dev/null || die "cannot clear stale lock $lock (permissions?)"
        continue
      fi
    fi
    if (( i >= LOCK_TIMEOUT_DS )); then
      die_code "$E_LOCK" "could not acquire lock at $lock after $((LOCK_TIMEOUT_DS/10))s (stale? rm -rf it)"
    fi
    sleep 0.1
    i=$((i + 1))
  done
  if ! echo "$$" > "$lock/pid"; then
    rm -rf "$lock" 2>/dev/null || true
    die "failed to write lock pidfile at $lock/pid"
  fi
  LOCK_HELD=1
  debug "acquire_lock: held by pid $$"
}

write_unlocked() {
  local tmp="${REGISTRY}.tmp.$$"
  if ! jq "$@" "$REGISTRY" > "$tmp"; then
    rm -f "$tmp"
    die "jq transform failed on $REGISTRY"
  fi
  if ! mv "$tmp" "$REGISTRY"; then
    rm -f "$tmp"
    die "failed to replace $REGISTRY (permissions? disk full?)"
  fi
}

# Emit a single claim in either plain port or JSON form.
emit_claim() {
  local name="$1" port="$2" json="$3"
  if (( json == 1 )); then
    jq -nc --arg n "$name" --argjson p "$port" '{name:$n, port:$p}'
  else
    echo "$port"
  fi
}

usage() {
  cat <<'EOF'
slipway — hand out ports to local dev apps so they don't collide.

Usage:
  slipway claim <name> [--port N] [--desc text] [--dry-run] [--json]
  slipway get <name> [--json]                    Print the claimed port (exit 3 if unclaimed)
  slipway release <name> [--if-claimed]          Free a claim; --if-claimed = idempotent
  slipway list [--json|--tsv]                    Show all claims
  slipway conflicts <port> [--json]              Show who holds <port>; exit 3 if free
  slipway check                                  (not yet implemented)
  slipway doctor                                 (not yet implemented)
  slipway config [show]                          Show auto_pool + registry_version
  slipway config auto-pool <s> <e>               Reconfigure auto_pool
  slipway version                                Print slipway version
  slipway reserved [list|--json]
  slipway reserved add <port> [note]             Add a reserved port
  slipway reserved remove <port>                 Remove a reserved port

Exit codes:
  0 ok  1 generic  2 usage  3 not-found  4 exhausted  5 lock-timeout  6 conflict  7 schema

Env:
  SLIPWAY_REGISTRY             Override registry path (default: ~/.config/slipway/registry.json)
  SLIPWAY_LOCK_TIMEOUT_DS      Lock acquisition timeout in tenths of seconds (default: 100)
  SLIPWAY_LIB                  Override commands library path (default: alongside the binary)
  SLIPWAY_DEBUG                If set to a non-zero value, log internal decisions to stderr
EOF
  exit "${1:-$E_USAGE}"
}

# shellcheck source=../lib/slipway/commands.sh
source "$SLIPWAY_LIB"

# `version` and help work without touching the registry, so users can
# recover from a corrupt/unreadable registry by reading the help output.
if (( $# == 0 )); then usage; fi
case "$1" in
  version|--version) echo "slipway $SLIPWAY_VERSION"; exit 0 ;;
  -h|--help|help)    usage 0 ;;
esac

sub="$1"; shift || true
ensure_registry
case "$sub" in
  claim)     cmd_claim "$@" ;;
  get)       cmd_get "$@" ;;
  release)   cmd_release "$@" ;;
  list)      cmd_list "$@" ;;
  conflicts) cmd_conflicts "$@" ;;
  check)     cmd_check "$@" ;;
  doctor)    cmd_doctor "$@" ;;
  config)    cmd_config "$@" ;;
  reserved)  cmd_reserved "$@" ;;
  *) usage ;;
esac
