#compdef slipway
# zsh completion for slipway
# Place on $fpath (e.g. /usr/local/share/zsh/site-functions/_slipway) and restart zsh.

_slipway_apps() {
  local registry="${SLIPWAY_REGISTRY:-$HOME/.config/slipway/registry.json}"
  if [[ -f "$registry" ]] && (( $+commands[jq] )); then
    local -a apps
    apps=( ${(f)"$(jq -r '.apps | keys[]' "$registry" 2>/dev/null)"} )
    _describe 'apps' apps
  fi
}

_slipway() {
  local -a subs
  subs=(
    'claim:reserve next free range'
    'reclaim:atomically resize an existing claim'
    'ensure:claim if missing, noop if claimed at same size'
    'get:print range for app'
    'release:free an app'
    'list:list all allocations'
    'conflicts:show who holds a port'
    'doctor:sanity-check the registry'
    'caddy:emit Caddyfile fragment for app'
    'reserved:manage reserved ranges'
    'help:show help'
  )

  if (( CURRENT == 2 )); then
    _describe 'subcommand' subs
    return
  fi

  case "${words[2]}" in
    get|release|reclaim|ensure|caddy)
      if (( CURRENT == 3 )); then
        _slipway_apps
      fi
      ;;
    list)
      _values 'format' '--json[machine-readable JSON]' '--tsv[tab-separated]' '--table[default table]'
      ;;
    claim)
      _values -s ' ' 'flags' '--dry-run[preview without persisting]' '--json[JSON output]'
      ;;
    reserved)
      if (( CURRENT == 3 )); then
        _values 'reserved subcommand' 'list' 'add' 'remove' '--json'
      fi
      ;;
  esac
}
_slipway "$@"
